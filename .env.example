# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://schulsani:changeme@localhost:5432/schulsaniapp
POSTGRES_PASSWORD=changeme

# =============================================================================
# API Server
# =============================================================================
PORT=3000

# Allowed CORS origin — set to your app's domain in production (e.g. https://app.example.com)
# Leave unset or use * for development only
# ALLOWED_ORIGIN=

# JWT secret — minimum 32 characters, generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-random-string-of-at-least-32-characters

# =============================================================================
# IServ Authentication
# IServ is the school management system used for login.
# Set ISERV_MOCK=true for local development without a real IServ instance.
# =============================================================================
ISERV_URL=https://your-school.iserv.eu
ISERV_MOCK=false

# IServ username of the first user who should automatically become owner/admin
FIRST_ADMIN_USERNAME=firstname.lastname

# =============================================================================
# Mobile App (Expo)
# EXPO_PUBLIC_* variables are bundled into the app at build time.
# =============================================================================
# API domain (host:port) — the app prepends https:// automatically.
# For local dev with Docker: use your machine's LAN IP, e.g. 192.168.1.x:3000
EXPO_PUBLIC_DOMAIN=localhost:3000
